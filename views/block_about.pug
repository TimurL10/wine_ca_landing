section.music-party-about
  span.music-party-about__decor LIVE MUSIC
  span.music-party-about__decor-vertical SING TOGETHER
  span.music-party-about__monogram MP

  .music-party-about__stamp
    span MUSIC PARTY
    span LIVE SESSION
    span MOSCOW

  .container.position-relative.py-5(
    style="max-width:1100px; z-index:1;"
  )
    .music-party-panel
      .row.g-0
        // Описание
        .col-lg-7
          .music-party-description
            span.music-party-eyebrow 02 / О формате

            h2.music-party-title
              | Что такое
              br
              span Music Party?

            p.music-party-text
              | Music Party — это формат мероприятия, где гости объединяются
              | в общем музыкальном настроении.

            p.music-party-text
              | Это событие, в котором рождается атмосфера живого исполнения
              | и единства. Гости становятся частью музыкального процесса
              | и поют вместе с артистами.

            p.music-party-text
              | Слова песен выводятся на экран или оформляются в стильные
              | песенники, чтобы каждый мог легко включиться в процесс —
              | без стеснения и формальностей.

            p.music-party-text.mb-0
              | Вечер, где музыка объединяет людей, создаёт ощущение единства
              | и превращает гостей в участников одного общего музыкального момента.

        // Шаги
        .col-lg-5
          .music-party-steps
            span.music-party-eyebrow 03 / Как проходит вечер

            h2.music-party-steps-title 4 простых шага

            .row.g-2
              .col-6
                .music-party-step
                  span.music-party-step-number 01
                  h3 Выбираем формат
                  p Подбираем программу и музыкальное настроение.

              .col-6
                .music-party-step
                  span.music-party-step-number 02
                  h3 Добавляем опции
                  p Выбираем артистов, ведущего и оборудование.

              .col-6
                .music-party-step
                  span.music-party-step-number 03
                  h3 Выбираем площадку
                  p Подбираем уютный лофт или музыкальную студию.

              .col-6
                .music-party-step
                  span.music-party-step-number 04
                  h3 Поём вместе
                  p Создаём один общий живой музыкальный момент.

style.
  .music-party-about {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 85% 20%,
        rgba(141, 66, 72, .14),
        transparent 32%
      ),
      linear-gradient(
        135deg,
        #f1e8dc 0%,
        #eadfce 55%,
        #ddc8b3 100%
      );
    font-family: Georgia, "Times New Roman", serif;
  }

  .music-party-about__decor {
    position: absolute;
    top: 18px;
    left: 4%;
    color: rgba(111, 55, 52, .07);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(5rem, 13vw, 12rem);
    font-style: italic;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
  }

  .music-party-about__decor-vertical {
    position: absolute;
    top: 120px;
    right: 22px;
    color: rgba(111, 55, 52, .12);
    font-family: Arial, sans-serif;
    font-size: .9rem;
    font-weight: 700;
    letter-spacing: .35em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    pointer-events: none;
  }

  .music-party-about__monogram {
    position: absolute;
    right: 9%;
    bottom: 32px;
    color: rgba(111, 55, 52, .08);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(4rem, 9vw, 8rem);
    font-style: italic;
    line-height: 1;
    pointer-events: none;
  }

  .music-party-about__stamp {
    position: absolute;
    top: 90px;
    right: 9%;
    width: 130px;
    height: 130px;
    border: 1px solid rgba(111, 55, 52, .18);
    border-radius: 50%;
    color: rgba(111, 55, 52, .22);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-family: Arial, sans-serif;
    text-align: center;
    text-transform: uppercase;
    line-height: 1.2;
    letter-spacing: .12em;
    pointer-events: none;
  }

  .music-party-about__stamp span:nth-child(1) {
    font-size: .72rem;
    font-weight: 700;
  }

  .music-party-about__stamp span:nth-child(2) {
    margin-top: 4px;
    font-size: .6rem;
  }

  .music-party-about__stamp span:nth-child(3) {
    margin-top: 8px;
    font-size: .58rem;
  }

  .music-party-panel {
    position: relative;
    overflow: visible;
    border: 1px solid rgba(25, 13, 8, .82);
    border-radius: 10px 8px 12px 9px;
    background:
      radial-gradient(ellipse at 22% 18%, rgba(255, 214, 151, .16), transparent 18%),
      radial-gradient(ellipse at 75% 78%, rgba(0, 0, 0, .26), transparent 28%),
      repeating-linear-gradient(
        92deg,
        rgba(255, 210, 145, .05) 0,
        rgba(255, 210, 145, .05) 2px,
        transparent 2px,
        transparent 18px
      ),
      repeating-linear-gradient(
        6deg,
        rgba(255, 181, 105, .08) 0,
        rgba(255, 181, 105, .08) 1px,
        rgba(42, 20, 12, .08) 1px,
        rgba(42, 20, 12, .08) 7px
      ),
      linear-gradient(
        135deg,
        #1b0d08 0%,
        #35180f 32%,
        #4b2517 58%,
        #24100a 100%
      );
    box-shadow:
      0 38px 58px rgba(47, 27, 17, .34),
      0 12px 0 #120805,
      0 18px 24px rgba(47, 27, 17, .22),
      inset 0 2px 0 rgba(255, 215, 168, .12),
      inset 0 -28px 36px rgba(0, 0, 0, .24),
      inset 18px 0 28px rgba(0, 0, 0, .16);
    transform: rotate(-1.2deg);
    transform-origin: 52% 8%;
  }

  .music-party-panel::before {
    content: "";
    position: absolute;
    z-index: 1;
    top: -38px;
    left: 50%;
    width: 76%;
    height: 58px;
    border-top: 3px solid rgba(53, 28, 17, .52);
    border-radius: 50% 50% 0 0;
    background:
      radial-gradient(circle at left bottom, #2a150d 0 7px, transparent 8px),
      radial-gradient(circle at right bottom, #2a150d 0 7px, transparent 8px),
      linear-gradient(rgba(41, 22, 14, .85), rgba(41, 22, 14, .85));
    background-repeat: no-repeat;
    background-size: 18px 18px, 18px 18px, calc(100% - 28px) 3px;
    background-position: left 0 bottom 1px, right 0 bottom 1px, center top 12px;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .music-party-panel::after {
    content: "";
    position: absolute;
    z-index: 3;
    inset: 14px;
    border: 1px solid rgba(255, 210, 155, .14);
    border-radius: 7px;
    background:
      radial-gradient(circle at 18px 18px, rgba(17, 8, 5, .86) 0 5px, rgba(180, 113, 62, .35) 5.5px 7px, transparent 7.5px),
      radial-gradient(circle at calc(100% - 18px) 18px, rgba(17, 8, 5, .86) 0 5px, rgba(180, 113, 62, .35) 5.5px 7px, transparent 7.5px),
      radial-gradient(circle at 18px calc(100% - 18px), rgba(17, 8, 5, .86) 0 5px, rgba(180, 113, 62, .35) 5.5px 7px, transparent 7.5px),
      radial-gradient(circle at calc(100% - 18px) calc(100% - 18px), rgba(17, 8, 5, .86) 0 5px, rgba(180, 113, 62, .35) 5.5px 7px, transparent 7.5px);
    pointer-events: none;
  }

  .music-party-panel .row {
    position: relative;
    z-index: 2;
    overflow: hidden;
    border-radius: inherit;
  }

  .music-party-description {
    height: 100%;
    padding: 42px;
  }

  .music-party-eyebrow {
    display: block;
    margin-bottom: 12px;
    color: #e2a077;
    font-size: .72rem;
    font-style: italic;
    letter-spacing: .13em;
    text-transform: uppercase;
  }

  .music-party-title {
    margin-bottom: 25px;
    color: #fff4de;
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    font-weight: 400;
    line-height: .95;
  }

  .music-party-title span {
    color: #ffc38f;
    font-style: italic;
  }

  .music-party-text {
    max-width: 650px;
    margin-bottom: 13px;
    color: #ead7c1;
    font-family: Arial, sans-serif;
    font-size: .95rem;
    line-height: 1.65;
  }

  .music-party-steps {
    height: 100%;
    padding: 42px 30px;
    border-left: 1px solid rgba(255, 210, 155, .14);
    background:
      linear-gradient(90deg, rgba(0, 0, 0, .2), transparent 32%),
      rgba(0, 0, 0, .12);
  }

  .music-party-steps-title {
    margin-bottom: 20px;
    color: #fff4de;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 400;
  }

  .music-party-steps .col-6 {
    transition: transform .25s ease;
  }

  .music-party-steps .col-6:hover {
    transform: translateY(-6px);
  }

  .music-party-step {
    height: 100%;
    min-height: 145px;
    padding: 16px;
    border: 1px solid rgba(255, 220, 170, .14);
    border-radius: 4px 7px 5px 6px;
    background:
      linear-gradient(135deg, rgba(255, 216, 166, .08), rgba(0, 0, 0, .08)),
      rgba(255, 255, 255, .035);
    transition: border-color .25s ease, background .25s ease, box-shadow .25s ease;
  }

  .music-party-steps .col-6:hover .music-party-step {
    border-color: rgba(255, 216, 166, .28);
    background:
      linear-gradient(135deg, rgba(255, 216, 166, .12), rgba(0, 0, 0, .04)),
      rgba(255, 255, 255, .055);
    box-shadow: 0 12px 26px rgba(0, 0, 0, .2);
  }

  .music-party-step-number {
    display: block;
    margin-bottom: 8px;
    color: #ffc38f;
    font-size: 1.45rem;
    font-style: italic;
  }

  .music-party-step h3 {
    margin-bottom: 7px;
    color: #fff4de;
    font-family: Arial, sans-serif;
    font-size: .9rem;
    font-weight: 700;
  }

  .music-party-step p {
    margin: 0;
    color: #d8c2ad;
    font-family: Arial, sans-serif;
    font-size: .76rem;
    line-height: 1.45;
  }

  @media (max-width: 991.98px) {
    .music-party-description,
    .music-party-steps {
      padding: 28px;
    }

    .music-party-steps {
      border-top: 1px solid rgba(255, 210, 155, .14);
      border-left: 0;
    }

    .music-party-about__decor {
      top: 24px;
      left: 2%;
      font-size: 7rem;
    }

    .music-party-about__decor-vertical {
      right: 10px;
      font-size: .7rem;
      letter-spacing: .25em;
    }

    .music-party-about__stamp {
      top: 70px;
      right: 4%;
      width: 100px;
      height: 100px;
    }

    .music-party-about__monogram {
      right: 5%;
      bottom: 20px;
      font-size: 5rem;
    }
  }

  @media (max-width: 575.98px) {
    .music-party-panel {
      border-radius: 8px;
      transform: rotate(-.7deg);
    }

    .music-party-panel::before {
      top: -30px;
      width: 68%;
      height: 46px;
    }

    .music-party-panel::after {
      inset: 10px;
    }

    .music-party-description,
    .music-party-steps {
      padding: 22px;
    }

    .music-party-title {
      font-size: 2.6rem;
    }

    .music-party-step {
      min-height: 135px;
      padding: 13px;
    }

    .music-party-about__decor {
      top: 20px;
      font-size: 4.3rem;
    }

    .music-party-about__decor-vertical {
      display: none;
    }

    .music-party-about__stamp {
      top: 58px;
      right: 12px;
      width: 82px;
      height: 82px;
    }

    .music-party-about__stamp span:nth-child(1) {
      font-size: .52rem;
    }

    .music-party-about__stamp span:nth-child(2),
    .music-party-about__stamp span:nth-child(3) {
      font-size: .45rem;
    }

    .music-party-about__monogram {
      right: 12px;
      bottom: 12px;
      font-size: 3.6rem;
    }
  }
