  style.
    .studio-card__image {
      position: relative;
      height: 155px;
      overflow: hidden;
    }

    .studio-card__photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: opacity .3s ease;
    }

    .studio-card__photo--main {
      opacity: 1;
    }

    .studio-card__photo--hover {
      opacity: 0;
    }

    .studio-card:hover .studio-card__photo--main {
      opacity: 0;
    }

    .studio-card:hover .studio-card__photo--hover {
      opacity: 1;
    }