style.
  .wine-prices {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at 14% 18%, rgba(141, 66, 72, .18), transparent 28%),
      linear-gradient(145deg, #f4eadc 0%, #e9dbc8 48%, #d9c1a8 100%);
    font-family: Georgia, "Times New Roman", serif;
  }

  .wine-prices::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(88, 45, 37, .045) 0,
        rgba(88, 45, 37, .045) 1px,
        transparent 1px,
        transparent 22px
      );
    pointer-events: none;
  }

  .wine-prices__decor {
    position: absolute;
    top: 12px;
    left: 3%;
    color: rgba(111, 55, 52, .07);
    font-size: clamp(4.6rem, 12vw, 11rem);
    font-style: italic;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
  }

  .wine-prices__decor-side {
    position: absolute;
    right: 22px;
    bottom: 86px;
    color: rgba(111, 55, 52, .13);
    font-family: Arial, sans-serif;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .32em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    pointer-events: none;
  }

  .wine-prices__mark {
    position: absolute;
    right: 9%;
    top: 46px;
    color: rgba(111, 55, 52, .09);
    font-size: clamp(4rem, 9vw, 8rem);
    font-style: italic;
    line-height: 1;
    pointer-events: none;
  }

  .wine-prices__intro {
    max-width: 900px;
    margin-bottom: 30px;
  }

  .wine-prices__eyebrow {
    display: block;
    margin-bottom: 12px;
    color: #8d4248;
    font-size: .72rem;
    font-style: italic;
    font-weight: 700;
    letter-spacing: .13em;
    text-transform: uppercase;
  }

  .wine-prices__title {
    margin-bottom: 22px;
    color: #2d150f;
    font-size: clamp(2.6rem, 5vw, 4.7rem);
    font-weight: 400;
    line-height: .96;
  }

  .wine-prices__title span {
    color: #8d4248;
    font-style: italic;
  }

  .wine-prices__note {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    min-height: 100%;
    padding: 15px 16px;
    border: 1px solid rgba(82, 39, 30, .2);
    border-radius: 7px;
    background: rgba(255, 248, 236, .42);
  }

  .wine-prices__note-sign {
    flex: 0 0 auto;
    color: #8d4248;
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .wine-prices__note p {
    margin: 0;
    color: #4a2b22;
    font-family: Arial, sans-serif;
    font-size: .92rem;
    line-height: 1.55;
  }

  .wine-prices__board {
    position: relative;
    padding: 30px;
    border: 1px solid rgba(25, 13, 8, .78);
    border-radius: 10px 8px 12px 9px;
    background:
      radial-gradient(ellipse at 16% 10%, rgba(255, 213, 151, .18), transparent 22%),
      radial-gradient(ellipse at 85% 84%, rgba(0, 0, 0, .25), transparent 32%),
      repeating-linear-gradient(
        7deg,
        rgba(255, 181, 105, .08) 0,
        rgba(255, 181, 105, .08) 1px,
        rgba(42, 20, 12, .08) 1px,
        rgba(42, 20, 12, .08) 8px
      ),
      linear-gradient(135deg, #1b0d08 0%, #35180f 36%, #4b2517 64%, #20100a 100%);
    box-shadow:
      0 34px 56px rgba(47, 27, 17, .32),
      0 10px 0 #120805,
      inset 0 2px 0 rgba(255, 215, 168, .12),
      inset 0 -28px 36px rgba(0, 0, 0, .22);
  }

  .wine-prices__board::after {
    content: "";
    position: absolute;
    inset: 14px;
    border: 1px solid rgba(255, 210, 155, .14);
    border-radius: 7px;
    pointer-events: none;
  }

  .wine-prices__rail {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    margin-bottom: 18px;
    border-bottom: 1px solid rgba(255, 210, 155, .16);
    color: rgba(255, 244, 222, .52);
    font-size: .68rem;
    letter-spacing: .24em;
    text-transform: uppercase;
  }

  .wine-prices__rail span {
    padding-bottom: 10px;
  }

  .wine-prices__board .row {
    position: relative;
    z-index: 1;
  }

  .wine-prices__card {
    position: relative;
    height: 100%;
    min-height: 430px;
    padding: 26px 24px 24px;
    border: 1px solid rgba(255, 220, 170, .24);
    border-radius: 5px 8px 6px 7px;
    background:
      linear-gradient(180deg, rgba(255, 250, 235, .97), rgba(238, 217, 190, .95)),
      #f5ead9;
    box-shadow:
      inset 0 0 0 7px rgba(96, 44, 31, .06),
      0 18px 34px rgba(0, 0, 0, .22);
    transition: transform .25s ease, box-shadow .25s ease;
  }

  .wine-prices__card::before,
  .wine-prices__card::after {
    content: "";
    position: absolute;
    left: 22px;
    right: 22px;
    height: 1px;
    background: rgba(99, 49, 37, .18);
  }

  .wine-prices__card::before {
    top: 14px;
  }

  .wine-prices__card::after {
    bottom: 14px;
  }

  .wine-prices__card:hover {
    transform: translateY(-8px) rotate(-.35deg);
    box-shadow:
      inset 0 0 0 7px rgba(96, 44, 31, .07),
      0 28px 44px rgba(0, 0, 0, .28);
  }

  .wine-prices__card--gold {
    background:
      linear-gradient(180deg, rgba(255, 249, 226, .98), rgba(232, 204, 143, .96)),
      #f0db9c;
  }

  .wine-prices__card--platinum {
    background:
      linear-gradient(180deg, rgba(248, 250, 247, .98), rgba(207, 220, 215, .96)),
      #e2ebe6;
  }

  .wine-prices__label {
    text-align: center;
  }

  .wine-prices__tier {
    display: block;
    color: #6e2f35;
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-style: italic;
    line-height: 1;
  }

  .wine-prices__price {
    display: block;
    margin-top: 16px;
    color: #24100a;
    font-family: Arial, sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .wine-prices__person {
    display: block;
    margin-top: 4px;
    color: #7b5a4c;
    font-family: Arial, sans-serif;
    font-size: .74rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .wine-prices__divider {
    width: 74px;
    height: 74px;
    margin: 24px auto 20px;
    border: 1px solid rgba(110, 47, 53, .32);
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(110, 47, 53, .16) 0 4px, transparent 5px),
      linear-gradient(90deg, transparent 48%, rgba(110, 47, 53, .28) 49%, rgba(110, 47, 53, .28) 51%, transparent 52%),
      linear-gradient(0deg, transparent 48%, rgba(110, 47, 53, .28) 49%, rgba(110, 47, 53, .28) 51%, transparent 52%);
  }

  .wine-prices__list {
    margin: 0;
    padding: 0;
    list-style: none;
    color: #44251d;
    font-family: Arial, sans-serif;
    font-size: .92rem;
    line-height: 1.5;
  }

  .wine-prices__list li {
    position: relative;
    padding: 9px 0 9px 23px;
    border-top: 1px solid rgba(99, 49, 37, .12);
  }

  .wine-prices__list li::before {
    content: "";
    position: absolute;
    top: 17px;
    left: 2px;
    width: 9px;
    height: 9px;
    border: 1px solid #8d4248;
    border-radius: 50%;
    background: rgba(141, 66, 72, .12);
  }

  @media (max-width: 991.98px) {
    .wine-prices__board {
      padding: 24px;
    }

    .wine-prices__rail {
      display: none;
    }

    .wine-prices__card {
      min-height: auto;
    }

    .wine-prices__decor-side {
      right: 10px;
      font-size: .7rem;
      letter-spacing: .22em;
    }
  }

  @media (max-width: 575.98px) {
    .wine-prices__title {
      font-size: 2.7rem;
    }

    .wine-prices__board {
      padding: 18px;
      border-radius: 8px;
    }

    .wine-prices__board::after {
      inset: 10px;
    }

    .wine-prices__card {
      padding: 24px 20px 22px;
    }

    .wine-prices__decor {
      font-size: 4rem;
    }

    .wine-prices__decor-side {
      display: none;
    }

    .wine-prices__mark {
      right: 12px;
      top: 56px;
      font-size: 3.8rem;
    }
  }
