section.hero-apartment
  img.hero-apartment__bg(
    src="/images/Image Jul 21, 2026, 04_20_18 PM.png"
    alt="Квартирники"
  )

  .container.hero-apartment__inner
    .row.w-100.justify-content-end
      .col-lg-7
        .hero-apartment__content
          span.hero-apartment__eyebrow 01 / Квартирники

          h1.hero-apartment__title Квартирники

          p.hero-apartment__subtitle ближе к музыке

          p.hero-apartment__description
            | Камерные концерты в уютных лофтах и студиях,
            br
            | где между музыкантами и зрителями нет расстояния.

          span.hero-apartment__age 18+

  .hero-apartment__menu
    .container(style="max-width:990px;")
      .d-flex.flex-wrap.gap-2.py-3
        a.hero-apartment__link.hero-apartment__link--active(
          href="#prices"
        ) Цены

        a.hero-apartment__link(
          href="#games"
        ) Игры и активности

        a.hero-apartment__link(
          href="#services"
        ) Дополнительные услуги

        a.hero-apartment__link(
          href="#studios"
        ) Где проводим

        a.hero-apartment__link(
          href="#gallery"
        ) Галерея

style.
  .hero-apartment {
    position: relative;
    min-height: 700px;
    overflow: hidden;
  }

  .hero-apartment__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .9;
  }

  .hero-apartment__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    min-height: 620px;
    max-width: 990px;
  }

  .hero-apartment__content {
    padding: 34px;
    border: 1px solid rgba(255, 255, 255, .18);
    border-radius: 20px;
    background: rgba(18, 10, 6, .58);
    box-shadow: 0 20px 55px rgba(0, 0, 0, .32);
    backdrop-filter: blur(4px);
    color: #fff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, .7);
  }

  .hero-apartment__eyebrow {
    display: block;
    margin-bottom: 14px;
    color: #f5c8bd;
    font-family: Georgia, "Times New Roman", serif;
    font-size: .95rem;
    font-style: italic;
    font-weight: 600;
    letter-spacing: .06em;
  }

  .hero-apartment__title {
    margin: 0;
    color: #fff;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.3rem, 7vw, 6.4rem);
    font-weight: 400;
    line-height: .95;
    text-shadow: 0 4px 20px rgba(0, 0, 0, .9);
  }

  .hero-apartment__subtitle {
    margin: 8px 0 28px;
    color: #efb0a3;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.8rem, 3vw, 2.7rem);
    font-style: italic;
    line-height: 1.1;
    text-shadow: 0 3px 16px rgba(0, 0, 0, .85);
  }

  .hero-apartment__description {
    max-width: 500px;
    margin-bottom: 28px;
    color: #fff;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.8;
  }

  .hero-apartment__age {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 70px;
    height: 70px;
    border: 1px solid rgba(255, 255, 255, .85);
    border-radius: 50%;
    background: rgba(0, 0, 0, .18);
    color: #fff;
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
  }

  .hero-apartment__menu {
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, .28);
    background: rgba(15, 9, 6, .62);
    backdrop-filter: blur(5px);
  }

  .hero-apartment__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 9px 18px;
    border: 1px solid rgba(255, 255, 255, .4);
    background: rgba(255, 255, 255, .08);
    color: #fff;
    font-size: .8rem;
    letter-spacing: .04em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color .2s ease,
      border-color .2s ease;
  }

  .hero-apartment__link:hover,
  .hero-apartment__link--active {
    border-color: #8d4248;
    background: #8d4248;
    color: #fff;
  }

  @media (max-width: 991.98px) {
    .hero-apartment {
      min-height: auto;
    }

    .hero-apartment__inner {
      min-height: 560px;
      padding-top: 40px;
      padding-bottom: 40px;
    }

    .hero-apartment__content {
      padding: 26px;
    }
  }

  @media (max-width: 575.98px) {
    .hero-apartment__inner {
      min-height: 520px;
    }

    .hero-apartment__content {
      padding: 22px;
      border-radius: 16px;
    }

    .hero-apartment__title {
      font-size: 3.2rem;
    }

    .hero-apartment__description {
      font-size: 1rem;
      line-height: 1.6;
    }

    .hero-apartment__link {
      padding: 8px 12px;
      font-size: .72rem;
    }
  }